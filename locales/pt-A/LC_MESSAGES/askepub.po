msgid "Hola! Bienvenido a AskePub. Por favor, selecciona tu idioma:"
msgstr "Olá! Bem-vindo ao AskePub. Por favor, selecione o seu idioma:"

msgid "Idioma seleccionado: {lang}. Envíame un archivo .epub para comenzar."
msgstr "Idioma selecionado: {lang}. Envie-me um ficheiro .epub para começar."

msgid "Por favor, envía un archivo .epub válido."
msgstr "Por favor, envie um ficheiro .epub válido."

msgid "Archivo recibido. Analizando..."
msgstr "Ficheiro recebido. A analisar..."

msgid ""
"He encontrado {count} capítulos en este libro:\n"
"\n"
"{chapters}\n"
"\n"
"Escribe los números de los capítulos que quieres estudiar (ej: 1,3,5 o 1-5 "
"o '{all_word}')."
msgstr ""
"Encontrei {count} capítulos neste livro:\n"
"\n"
"{chapters}\n"
"\n"
"Escreva os números dos capítulos que pretende estudar (ex: 1,3,5 ou 1-5 ou "
"'{all_word}')."

msgid ""
"Selección no válida. Por favor, usa números separados por comas (1,3,5), "
"rangos (1-5), o escribe '{all_word}'."
msgstr ""
"Seleção inválida. Por favor, utilize números separados por vírgulas "
"(1,3,5), intervalos (1-5), ou escreva '{all_word}'."

#, python-brace-format
msgid ""
"Has seleccionado {count} capítulo(s). Tus preguntas actuales:\n"
"\n"
"{questions}\n"
"\n"
"¿Quieres personalizar las preguntas?"
msgstr ""
"Selecionou {count} capítulo(s). As suas perguntas atuais:\n"
"\n"
"{questions}\n"
"\n"
"Pretende personalizar as perguntas?"

msgid "Sí, personalizar"
msgstr "Sim, personalizar"

msgid "No, continuar"
msgstr "Não, continuar"

msgid "¿Qué deseas hacer?"
msgstr "O que pretende fazer?"

msgid "Editar pregunta"
msgstr "Editar pergunta"

msgid "Eliminar pregunta"
msgstr "Eliminar pergunta"

msgid "Añadir pregunta"
msgstr "Adicionar pergunta"

msgid "Continuar con la preparación"
msgstr "Continuar com a preparação"

msgid "Escribe el número de la pregunta a editar:"
msgstr "Escreva o número da pergunta a editar:"

#, python-brace-format
msgid "Escribe el nuevo texto para la pregunta {num}:"
msgstr "Escreva o novo texto para a pergunta {num}:"

msgid "Pregunta actualizada."
msgstr "Pergunta atualizada."

msgid "Escribe el número de la pregunta a eliminar:"
msgstr "Escreva o número da pergunta a eliminar:"

msgid "Pregunta eliminada."
msgstr "Pergunta eliminada."

msgid "No puedes eliminar la última pregunta."
msgstr "Não pode eliminar a última pergunta."

msgid "Escribe el texto de la nueva pregunta:"
msgstr "Escreva o texto da nova pergunta:"

msgid "Pregunta añadida."
msgstr "Pergunta adicionada."

msgid "Preparando tus notas de estudio. Esto puede tardar unos minutos..."
msgstr "A preparar as suas notas de estudo. Isto pode demorar alguns minutos..."

msgid "Aquí tienes tus archivos:"
msgstr "Aqui estão os seus ficheiros:"

msgid "ePub anotado con tus notas de estudio"
msgstr "ePub anotado com as suas notas de estudo"

msgid "Documento Word con las notas"
msgstr "Documento Word com as notas"

msgid "Documento PDF con las notas"
msgstr "Documento PDF com as notas"

msgid "¿Deseas estudiar otro libro o más capítulos?"
msgstr "Pretende estudar outro livro ou mais capítulos?"

msgid "Sí"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "Gracias por usar AskePub. Usa /start para comenzar de nuevo."
msgstr "Obrigado por usar o AskePub. Utilize /start para começar de novo."

msgid "Error al procesar el archivo. Por favor, intenta con otro .epub."
msgstr "Erro ao processar o ficheiro. Por favor, tente com outro .epub."

#, python-brace-format
msgid "Has alcanzado el límite. Intenta de nuevo en {minutes} minutos."
msgstr "Atingiu o limite. Tente novamente em {minutes} minutos."

msgid "No tienes permiso para usar este bot."
msgstr "Não tem permissão para utilizar este bot."

msgid "Operación cancelada."
msgstr "Operação cancelada."

msgid "todos"
msgstr "todos"

msgid ""
"¿Quieres mantener tus preguntas anteriores o usar las predeterminadas?"
msgstr ""
"Pretende manter as suas perguntas anteriores ou usar as predefinidas?"

msgid "Mantener preguntas"
msgstr "Manter perguntas"

msgid "Usar predeterminadas"
msgstr "Usar predefinidas"

msgid "Resume los puntos clave y argumentos principales de esta sección"
msgstr "Resuma os pontos-chave e os argumentos principais desta secção"

msgid "¿Cuáles son los conceptos o términos más importantes introducidos?"
msgstr "Quais são os conceitos ou termos mais importantes introduzidos?"

msgid "¿Qué preguntas plantea o deja sin responder esta sección?"
msgstr "Que perguntas levanta ou deixa sem resposta esta secção?"
