msgid "Hola! Bienvenido a AskePub. Por favor, selecciona tu idioma:"
msgstr "Hallo! Willkommen bei AskePub. Bitte wähle deine Sprache:"

msgid "Idioma seleccionado: {lang}. Envíame un archivo .epub para comenzar."
msgstr "Sprache ausgewählt: {lang}. Sende mir eine .epub-Datei, um zu beginnen."

msgid "Por favor, envía un archivo .epub válido."
msgstr "Bitte sende eine gültige .epub-Datei."

msgid "Archivo recibido. Analizando..."
msgstr "Datei empfangen. Wird analysiert..."

msgid ""
"He encontrado {count} capítulos en este libro:\n"
"\n"
"{chapters}\n"
"\n"
"Escribe los números de los capítulos que quieres estudiar (ej: 1,3,5 o 1-5 "
"o '{all_word}')."
msgstr ""
"Ich habe {count} Kapitel in diesem Buch gefunden:\n"
"\n"
"{chapters}\n"
"\n"
"Gib die Kapitelnummern ein, die du studieren möchtest (z.B.: 1,3,5 oder "
"1-5 oder '{all_word}')."

msgid ""
"Selección no válida. Por favor, usa números separados por comas (1,3,5), "
"rangos (1-5), o escribe '{all_word}'."
msgstr ""
"Ungültige Auswahl. Bitte verwende durch Kommas getrennte Zahlen (1,3,5), "
"Bereiche (1-5), oder schreibe '{all_word}'."

#, python-brace-format
msgid ""
"Has seleccionado {count} capítulo(s). Tus preguntas actuales:\n"
"\n"
"{questions}\n"
"\n"
"¿Quieres personalizar las preguntas?"
msgstr ""
"Du hast {count} Kapitel ausgewählt. Deine aktuellen Fragen:\n"
"\n"
"{questions}\n"
"\n"
"Möchtest du die Fragen anpassen?"

msgid "Sí, personalizar"
msgstr "Ja, anpassen"

msgid "No, continuar"
msgstr "Nein, fortfahren"

msgid "¿Qué deseas hacer?"
msgstr "Was möchtest du tun?"

msgid "Editar pregunta"
msgstr "Frage bearbeiten"

msgid "Eliminar pregunta"
msgstr "Frage löschen"

msgid "Añadir pregunta"
msgstr "Frage hinzufügen"

msgid "Continuar con la preparación"
msgstr "Mit der Vorbereitung fortfahren"

msgid "Escribe el número de la pregunta a editar:"
msgstr "Gib die Nummer der zu bearbeitenden Frage ein:"

#, python-brace-format
msgid "Escribe el nuevo texto para la pregunta {num}:"
msgstr "Gib den neuen Text für Frage {num} ein:"

msgid "Pregunta actualizada."
msgstr "Frage aktualisiert."

msgid "Escribe el número de la pregunta a eliminar:"
msgstr "Gib die Nummer der zu löschenden Frage ein:"

msgid "Pregunta eliminada."
msgstr "Frage gelöscht."

msgid "No puedes eliminar la última pregunta."
msgstr "Du kannst die letzte Frage nicht löschen."

msgid "Escribe el texto de la nueva pregunta:"
msgstr "Gib den Text der neuen Frage ein:"

msgid "Pregunta añadida."
msgstr "Frage hinzugefügt."

msgid "Preparando tus notas de estudio. Esto puede tardar unos minutos..."
msgstr "Deine Lernnotizen werden vorbereitet. Dies kann einige Minuten dauern..."

msgid "Aquí tienes tus archivos:"
msgstr "Hier sind deine Dateien:"

msgid "ePub anotado con tus notas de estudio"
msgstr "Annotiertes ePub mit deinen Lernnotizen"

msgid "Documento Word con las notas"
msgstr "Word-Dokument mit den Notizen"

msgid "Documento PDF con las notas"
msgstr "PDF-Dokument mit den Notizen"

msgid "¿Deseas estudiar otro libro o más capítulos?"
msgstr "Möchtest du ein anderes Buch oder weitere Kapitel studieren?"

msgid "Sí"
msgstr "Ja"

msgid "No"
msgstr "Nein"

msgid "Gracias por usar AskePub. Usa /start para comenzar de nuevo."
msgstr "Danke, dass du AskePub genutzt hast. Verwende /start, um neu zu beginnen."

msgid "Error al procesar el archivo. Por favor, intenta con otro .epub."
msgstr "Fehler beim Verarbeiten der Datei. Bitte versuche es mit einer anderen .epub."

#, python-brace-format
msgid "Has alcanzado el límite. Intenta de nuevo en {minutes} minutos."
msgstr "Du hast das Limit erreicht. Versuche es in {minutes} Minuten erneut."

msgid "No tienes permiso para usar este bot."
msgstr "Du hast keine Berechtigung, diesen Bot zu verwenden."

msgid "Operación cancelada."
msgstr "Vorgang abgebrochen."

msgid "todos"
msgstr "alle"

msgid ""
"¿Quieres mantener tus preguntas anteriores o usar las predeterminadas?"
msgstr ""
"Möchtest du deine vorherigen Fragen behalten oder die Standardfragen "
"verwenden?"

msgid "Mantener preguntas"
msgstr "Fragen behalten"

msgid "Usar predeterminadas"
msgstr "Standardfragen verwenden"

msgid "Resume los puntos clave y argumentos principales de esta sección"
msgstr "Fasse die wichtigsten Punkte und Hauptargumente dieses Abschnitts zusammen"

msgid "¿Cuáles son los conceptos o términos más importantes introducidos?"
msgstr "Welche sind die wichtigsten eingeführten Konzepte oder Begriffe?"

msgid "¿Qué preguntas plantea o deja sin responder esta sección?"
msgstr "Welche Fragen wirft dieser Abschnitt auf oder lässt er unbeantwortet?"
